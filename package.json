{
  "name": "projects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "build:turbopack": "next build",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:list": "tsx src/db/migrate.ts --list",
    "dev": "next dev --webpack -p 5000",
    "dev:monitored": "next dev --webpack -p 5000",
    "dev:turbopack": "next dev --turbopack -p 5000",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint",
    "start": "next start -p 5000",
    "pretypecheck": "node -e \"require('node:fs').rmSync('.next/dev', { recursive: true, force: true })\"",
    "ts-check": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:api": "vitest run tests/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:core": "playwright tests/e2e/playwright/core-business.spec.ts",
    "test:e2e:management": "playwright tests/e2e/playwright/management.spec.ts",
    "test:e2e:settings": "playwright tests/e2e/playwright/settings.spec.ts",
    "test:e2e:solutions": "playwright tests/e2e/playwright/solution-management.spec.ts",
    "test:e2e:lifecycle": "playwright tests/e2e/playwright/solution-lifecycle.spec.ts",
    "test:e2e:stability-sweep": "playwright test tests/e2e/playwright/stability-sweep.spec.ts",
    "test:e2e:stability-sweep:5004": "powershell -Command \"$env:PLAYWRIGHT_EXTERNAL_SERVER='1'; $env:PLAYWRIGHT_BASE_URL='http://localhost:5004'; node ./node_modules/@playwright/test/cli.js test tests/e2e/playwright/stability-sweep.spec.ts\"",
    "test:e2e:acceptance-sweep:5004": "powershell -Command \"$env:PLAYWRIGHT_EXTERNAL_SERVER='1'; $env:PLAYWRIGHT_BASE_URL='http://localhost:5004'; node ./node_modules/@playwright/test/cli.js test tests/e2e/playwright/stability-sweep.spec.ts tests/e2e/playwright/data-screen-formal.spec.ts\"",
    "verify:acceptance:5004": "corepack pnpm run test:e2e:acceptance-sweep:5004",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:unit:coverage": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "playwright test tests/e2e/playwright/smoke.spec.ts",
    "test:all": "vitest run && playwright test",
    "verify:phase1": "corepack pnpm run typecheck && corepack pnpm run test:unit && corepack pnpm run test:api && corepack pnpm run test:smoke && corepack pnpm build",
    "verify:pr": "corepack pnpm run typecheck && corepack pnpm run test:unit && corepack pnpm run test:api",
    "verify:release-candidate": "corepack pnpm run verify:pr && corepack pnpm build && corepack pnpm run test:smoke",
    "verify:release": "corepack pnpm run verify:release-candidate && corepack pnpm run test:e2e",
    "ops:backup:db": "powershell -ExecutionPolicy Bypass -File ./scripts/ops/backup-database.ps1",
    "ops:restore:db": "powershell -ExecutionPolicy Bypass -File ./scripts/ops/restore-database.ps1",
    "vitest": "vitest",
    "test:data": "npx tsx tests/data-integrity/run-all-tests.ts",
    "test:data:consistency": "npx tsx tests/data-integrity/test-data-consistency.ts",
    "test:data:spatial": "npx tsx tests/data-integrity/test-spatial-data.ts",
    "test:data:dashboard": "npx tsx tests/data-integrity/test-dashboard-data.ts",
    "data:fix": "npx tsx tests/data-integrity/data-fix-tool.ts",
    "import:manual-ledger": "tsx scripts/import/manual-ledger-projects.ts",
    "import:manual-ledger:solutions": "tsx scripts/import/manual-ledger-solutions.ts",
    "phase5:build-samples": "tsx scripts/phase5/build-business-acceptance-samples.ts",
    "phase5:collect-evidence": "tsx scripts/phase5/collect-business-acceptance-evidence.ts",
    "phase5:collect-ui-evidence": "tsx scripts/phase5/collect-business-acceptance-ui-evidence.ts"
  },
